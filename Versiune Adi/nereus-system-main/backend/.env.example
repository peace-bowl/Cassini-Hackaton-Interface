# ─── Copernicus Data Space Ecosystem credentials ──────────────────────────────
# Register free at https://dataspace.copernicus.eu/
# Used by the openEO client for Sentinel-2 L2A access.
CDSE_USERNAME=your_email@example.com
CDSE_PASSWORD=your_password

# ─── Demo / offline mode ──────────────────────────────────────────────────────
# Set to true to always use synthetic demo data (no Copernicus calls).
# Keep true for local dev/demo; set false in production with real credentials.
NEREUS_OFFLINE_MODE=true

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite path — change to /app/data/nereus.db when running in Docker
DATABASE_URL=sqlite:///./nereus.db

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or "*" for open (demo only)
CORS_ORIGINS=*

# ─── Spectral thresholds (advanced) ───────────────────────────────────────────
NDCI_THRESHOLD=0.0
TURBIDITY_THRESHOLD=1.15
MIN_ANOMALY_AREA_HA=2.0
